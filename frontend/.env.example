# Backend base URL — used for WebSocket and API proxy (no trailing slash)
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Supabase Auth (Dashboard: Project Settings → API → URL + anon key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Groq for profile drill-down (if used from API routes)
# GROQ_API_KEY=
